{
  "name": "nintroller",
  "version": "0.1.0",
  "description": "Nintendo Switch automation middleware platform",
  "license": "GPL-3.0-or-later",
  "keywords": ["nintendo-switch", "automation", "bluetooth", "controller", "esp32"],
  "main": "dist/cli.js",
  "bin": {
    "nintroller": "dist/cli.js"
  },
  "files": [
    "dist/",
    ".opencode/skills/nintroller/SKILL.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "web:dev": "vite",
    "web:build": "vite build",
    "test": "echo \"Tests not yet configured\"",
    "prepublishOnly": "pnpm run build"
  },
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "commander": "^12.1.0",
    "serialport": "^12.0.0",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^22.0.0",
    "@types/express": "^4.17.21",
    "tsx": "^4.16.0",
    "vite": "^5.4.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0"
  }
}
